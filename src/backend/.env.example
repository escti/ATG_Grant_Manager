# ------------------------------------------------------------------------------
# OGM - ARQUIVO DE EXEMPLO DE CONFIGURAÇÃO (.env)
# Renomeie para .env e preencha com seus dados reais.
# ------------------------------------------------------------------------------

# Configurações do Banco de Dados Oracle (Usuário de Serviço)
DB_USER=SVC_DBA
DB_PASS=SUA_SENHA_AQUI_PROTEGIDA

# Configurações de Integração com Jira API
JIRA_BASE_URL=https://autoglass.atlassian.net
JIRA_USER=seu_email_operacional@autoglass.com.br
JIRA_API_TOKEN=SEU_TOKEN_GERADO_NO_ATLASSIAN_ID

# Campos Customizados do Jira (Ajuste conforme seu Service Desk)
JIRA_APPROVAL_FIELD=customfield_10100
JIRA_EXPECTED_APPROVAL_VALUE=Aprovado

# ------------------------------------------------------------------------------
# ATENÇÃO: Garanta que o arquivo final .env tenha permissões restritas (600).
# ------------------------------------------------------------------------------
